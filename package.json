{
  "name": "claude-code-preview",
  "displayName": "Claude Code Preview",
  "description": "Render Claude Code responses with LaTeX math, code highlighting, and markdown formatting in VS Code's markdown preview.",
  "version": "0.3.4",
  "publisher": "simonedambrogio",
  "author": {
    "name": "Simone D'Ambrogio"
  },
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude code",
    "anthropic",
    "markdown",
    "preview",
    "latex",
    "math",
    "katex"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/simonedambrogio/claude-code-preview.git"
  },
  "bugs": {
    "url": "https://github.com/simonedambrogio/claude-code-preview/issues"
  },
  "homepage": "https://github.com/simonedambrogio/claude-code-preview#readme",
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeCodePreview.open",
        "title": "Claude Code Preview: Open Latest Response to the Side"
      },
      {
        "command": "claudeCodePreview.openCurrent",
        "title": "Claude Code Preview: Open Latest Response"
      }
    ],
    "keybindings": [
      {
        "command": "claudeCodePreview.open",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "terminalFocus"
      },
      {
        "command": "claudeCodePreview.openCurrent",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "terminalFocus"
      }
    ]
  }
}
